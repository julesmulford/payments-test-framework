{
  "name": "@payments-framework/contract-tests",
  "version": "1.0.0",
  "scripts": {
    "test:consumer": "jest --testPathPattern=consumers --forceExit",
    "test:provider": "jest --testPathPattern=providers --forceExit",
    "publish": "ts-node src/scripts/publish-pacts.ts",
    "can-i-deploy": "bash src/scripts/can-i-deploy.sh"
  },
  "dependencies": {
    "@pact-foundation/pact": "^12.3.0",
    "@payments-framework/shared": "*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testTimeout": 30000,
    "testMatch": ["**/*.pact.spec.ts", "**/*.provider.spec.ts"]
  }
}
